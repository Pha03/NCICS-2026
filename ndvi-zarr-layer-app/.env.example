# Copy to .env and fill in your R2 public URL for the pyramid IceChunk store.
#
# Option 1 — Cloudflare R2 public bucket URL (enable "Public access" in the R2 dashboard):
#   https://pub-<hash>.r2.dev/ndvi-cdr-pyramid
#
# Option 2 — Direct R2 endpoint (works if running from a trusted origin or CORS is configured):
#   https://<accountId>.r2.cloudflarestorage.com/osc-pub/ndvi-cdr-pyramid

VITE_ICECHUNK_URL=https://r2-pub.openscicomp.io/ndvi-cdr-pyramid
